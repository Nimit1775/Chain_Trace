# Set to "true" to run WITHOUT TigerGraph (uses built-in mock data)
DEMO_MODE=true

# TigerGraph Savanna — get from workspace "Connect" tab
TG_HOST=https://your-workspace.i.tgcloud.io
TG_USERNAME=tigergraph
TG_PASSWORD=your_password_here
TG_GRAPH_NAME=ChainTrace

# AI — add whichever key you have
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
AI_PROVIDER=openai
